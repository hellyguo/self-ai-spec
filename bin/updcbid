#!/bin/bash

# 导入公共函数
SCRIPT_DIR="$HOME/code/markdown/self-ai-spec/bin"
source "$SCRIPT_DIR/common.sh"

# 配置工具名称
TOOL_NAME="codebuddy"

# 验证并保存会话ID
validate_and_save_session_id "$TOOL_NAME"

# 如果出错，显示帮助信息
if [ $? -ne 0 ]; then
    echo ""
    show_update_id_usage "$(basename "$0")" "$TOOL_NAME"
fi

