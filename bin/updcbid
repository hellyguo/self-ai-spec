#!/bin/bash

# 检查环境变量
if [ -z "$AI_SPEC_ROOT" ]; then
    echo "错误: 环境变量 AI_SPEC_ROOT 未设置"
    echo "请设置: export AI_SPEC_ROOT=/path/to/self-ai-spec"
    exit 1
fi

# 从环境变量定位公共函数
COMMON_SH="$AI_SPEC_ROOT/bin/common.sh"
if [ ! -f "$COMMON_SH" ]; then
    echo "错误: 公共函数文件不存在: $COMMON_SH"
    echo "请确保 AI_SPEC_ROOT 指向正确的 self-ai-spec 目录"
    exit 1
fi

source "$COMMON_SH"

# 配置工具名称
TOOL_NAME="codebuddy"

# 验证并保存会话ID
validate_and_save_session_id "$TOOL_NAME"

# 如果出错，显示帮助信息
if [ $? -ne 0 ]; then
    echo ""
    show_update_id_usage "$(basename "$0")" "$TOOL_NAME"
fi

