#!/bin/bash

# 导入公共函数
SCRIPT_DIR=$(dirname "$0")
source "$SCRIPT_DIR/common.sh"

# 配置工具变量
TOOL_NAME="codebuddy"
TOOL_CMD="codebuddy"
ID_FILE=".codebuddy_id"

# 主逻辑
if [ $# -eq 0 ]; then
    # 尝试恢复会话
    check_and_resume_session "$TOOL_CMD" "$ID_FILE"
else
    # 启动新会话
    LANG_ARG="$1"
    
    # 检查模板是否存在
    check_and_copy_template "$LANG_ARG" "$AGENT_TEMPLATE_DIR" "$TOOL_NAME"
    
    # 启动新会话
    start_new_session "$TOOL_CMD" "$LANG_ARG"
fi

