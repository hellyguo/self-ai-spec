#!/bin/bash

id_file=.claudecode_id
dst_file=CLAUDE.md

src_dir=~/code/markdown/self-ai-spec/agent-template

if [ -e $dst_file ];
then
    echo exist define, skip
else
    echo cp from defined agent md

    if [ $# -eq 1 ];
    then
        echo $1
        case $1 in
            java)
                src_file=AGENTS.java.md
                ;;
            ansi_c)
                src_file=AGENTS.ansi_c.md
                ;;
            cpp)
                src_file=AGENTS.cpp.md
                ;;
            rust)
                src_file=AGENTS.rust.md
                ;;
            python)
                src_file=AGENTS.python.md
                ;;
            js)
                src_file=AGENTS.js.md
                ;;
            blank)
                src_file=AGENTS.blank.md
                ;;
            *)
                echo $1 not a valid program language, please set another language
                exit 1
                ;;
        esac
    else
        echo need to set program language
        exit 1
    fi

    cp $src_dir/$src_file $dst_file
fi

if [ -e $id_file ];
then
    echo exist prev id, use the id
    ID=$(cat $id_file)
    claude --resume $ID
else
    echo start as new
    claude
fi

