#!/bin/bash

# 导入公共函数
SCRIPT_DIR=$(dirname "$0")
source "$SCRIPT_DIR/common.sh"

# 配置变量
ID_FILE=".opencode_id"
DST_FILE="AGENTS.md"
TOOL_NAME="opencode"

# 检查会话恢复
if check_and_resume_session "$ID_FILE" "-s" "$TOOL_NAME"; then
    exit 0
fi

# 新会话：需要语言参数
if [ $# -eq 1 ]; then
    LANGUAGE="$1"
else
    echo "Error: First session needs language parameter"
    echo ""
    show_usage "$(basename "$0")" "$TOOL_NAME"
    exit 1
fi

# 检查并复制模板
check_and_copy_template "$DST_FILE" "$LANGUAGE"

# 启动新会话
start_new_session "opencode" "$TOOL_NAME"

