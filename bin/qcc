#!/bin/bash

# 导入公共函数
SCRIPT_DIR=$(dirname "$0")
source "$SCRIPT_DIR/common.sh"

# 配置工具变量
TOOL_NAME="qodercli"
TOOL_CMD="qodercli"

# qodercli不支持会话恢复，始终需要语言参数
if [ $# -eq 0 ]; then
    echo "错误: qodercli 需要语言参数（不支持会话恢复）"
    echo ""
    show_usage "$(basename "$0")" "$TOOL_NAME"
    exit 1
fi

LANG_ARG="$1"

# 检查模板是否存在
check_and_copy_template "$LANG_ARG" "$AGENT_TEMPLATE_DIR" "$TOOL_NAME"

# 启动qodercli
start_new_session "$TOOL_CMD" "$LANG_ARG"

