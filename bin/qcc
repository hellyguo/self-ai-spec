#!/bin/bash

# 导入公共函数
SCRIPT_DIR=$(dirname "$0")
source "$SCRIPT_DIR/common.sh"

# 配置变量
DST_FILE="AGENTS.md"
TOOL_NAME="qodercli"

# qodercli不支持会话恢复，始终需要语言参数
if [ $# -eq 0 ]; then
    echo "Error: qodercli needs language parameter (no session resume support)"
    echo ""
    echo "Usage: $(basename "$0") <language>"
    echo "支持的语音: java, ansi_c, cpp, rust, python, js, blank"
    exit 1
fi

LANGUAGE="$1"

# 检查并复制模板
check_and_copy_template "$DST_FILE" "$LANGUAGE"

# 启动qodercli
start_new_session "qodercli" "$TOOL_NAME"

